# 服务器配置
PORT=4000

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET=privanest-secret-key-change-in-production

# 媒体库路径配置（支持多个路径，逗号分隔）
# 例如：/Volumes/Media/Movies,/Volumes/Data/Videos,/home/user/media
MEDIA_PATHS=/default/media/path

# 封面存储路径（可选，用于手动上传的封面）
COVER_PATH=./storage/covers

# 数据库配置（使用 SQLite）
DB_PATH=./storage/database.db
