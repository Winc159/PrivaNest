# 服务器端口
PORT=4000

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET=privanest-secret-key

# 媒体库路径（多个路径用逗号分隔）
# macOS 示例：MEDIA_PATHS=/Volumes/Media/Movies,/Volumes/Data/Series
# Linux 示例：MEDIA_PATHS=/media/movies,/data/series
# Windows 示例：MEDIA_PATHS=D:\Media\Movies,E:\Data\Series
MEDIA_PATHS=/default/media

# 封面存储路径
COVER_PATH=./storage/covers

# 数据库文件路径
DB_PATH=./storage/database.db
