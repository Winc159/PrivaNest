# ===========================================
# PrivaNest Backend Configuration
# ===========================================

# 服务端口
PORT=4000

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET=privanest-secret-key-change-in-production

# 媒体库路径（逗号分隔多个路径）
MEDIA_PATHS=/Volumes/Media/Movies,/Volumes/Media/TVShows

# 封面存储路径
COVER_PATH=./storage/covers

# SQLite 数据库路径
DB_PATH=./storage/database.db

# ===========================================
# Redis Configuration (Optional)
# ===========================================
# 如果不配置 Redis，系统将自动使用内存缓存作为降级方案

# Redis 服务器地址
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 密码（如果没有设置密码，请留空或注释）
# REDIS_PASSWORD=your-redis-password

# Redis 数据库编号（0-15）
REDIS_DB=0
